{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "oxlint",
    "cap:build": "APP_BUILD=capacitor nuxt build && node scripts/cap-extract-spa.mjs",
    "build:android": "APP_BUILD=capacitor nuxt build && node scripts/cap-extract-spa.mjs && npx cap sync android",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/push-notifications": "^8.0.3",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "capacitor-sunmi-printer": "file:./plugins/capacitor-sunmi-printer",
    "@iconify-json/lucide": "^1.2.103",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/ui": "^4.6.1",
    "@pinia/nuxt": "^0.11.3",
    "graphql": "^16.13.2",
    "graphql-tag": "^2.12.6",
    "graphql-ws": "^6.0.8",
    "nuxt": "^4.4.2",
    "oidc-client-ts": "^3.5.0",
    "pinia-plugin-persistedstate": "^4.7.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@nuxt/test-utils": "^4.0.2",
    "@nuxtjs/i18n": "^10.3.0",
    "@types/node": "^24.12.2",
    "oxlint": "^1.61.0",
    "tailwindcss": "^4.2.4",
    "vitest": "^4.1.5"
  },
  "optionalDependencies": {
    "@esbuild/linux-arm64": "^0.28.0",
    "@esbuild/linux-x64": "^0.28.0",
    "@oxc-minify/binding-linux-arm64-gnu": "^0.128.0",
    "@oxc-minify/binding-linux-x64-gnu": "^0.128.0",
    "@oxc-parser/binding-linux-arm64-gnu": "^0.128.0",
    "@oxc-parser/binding-linux-x64-gnu": "^0.128.0",
    "@oxc-transform/binding-linux-arm64-gnu": "^0.128.0",
    "@oxc-transform/binding-linux-x64-gnu": "^0.128.0",
    "@rollup/rollup-linux-arm64-gnu": "^4.60.2",
    "@rollup/rollup-linux-x64-gnu": "^4.60.2",
    "@tailwindcss/oxide-linux-arm64-gnu": "^4.2.4",
    "@tailwindcss/oxide-linux-x64-gnu": "^4.2.4",
    "lightningcss-linux-arm64-gnu": "^1.32.0",
    "lightningcss-linux-x64-gnu": "^1.32.0"
  }
}
